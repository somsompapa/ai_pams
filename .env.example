# PAMS 환경변수 예시 (실제 값은 .env에 작성하고 커밋하지 않는다)

# 실행 환경: local | dev | prod
PAMS_ENV=local

# 로그 레벨: DEBUG | INFO | WARNING | ERROR
PAMS_LOG_LEVEL=INFO

# Claude API (ai_analysis 컨텍스트에서 사용 - 계산이 아닌 설명/요약 용도)
ANTHROPIC_API_KEY=
# AI 해설에 사용할 모델 (미설정 시 기본값 사용)
PAMS_AI_MODEL=claude-sonnet-5

# 시장 데이터 공급자 자격증명 (Phase 2 이후 market_data.infrastructure 에서 사용)
MARKET_DATA_PROVIDER=
MARKET_DATA_API_KEY=

# 종목분석(equity) 탭의 "재무제표 자동조회"에 필요. 미설정이면 /api/equity-score가
# 502로 실패한다(값을 지어내지 않고 명시적으로 실패시킨다).
# SEC EDGAR: 연락처 포함 User-Agent가 SEC 요구사항(없으면 403) — 본인 이메일 입력.
SEC_EDGAR_CONTACT_EMAIL=
# DART Open API: opendart.fss.or.kr 회원가입 후 무료 발급.
DART_API_KEY=
# 서버(.env.deploy)에 이 두 값을 채우려면 deploy/set-equity-api-keys.sh 참고.

# 대시보드 서버 주소/포트. 같은 와이파이의 폰에서 보려면 PAMS_HOST=0.0.0.0
PAMS_HOST=127.0.0.1
PAMS_PORT=8000

# 대시보드 접근 비밀번호. 설정하면 모든 화면/API에 로그인이 필요하다 (미설정 시 개방).
# 집 밖(VPS 등)에 배포할 때는 반드시 설정하고 HTTPS 또는 Tailscale과 함께 사용하라.
PAMS_PASSWORD=

# 프로젝트 루트 오버라이드 (Docker 등 배포 환경에서 config/data 위치 지정)
PAMS_ROOT=

# 텔레그램 알림 (make alert). 봇 생성: @BotFather, chat_id 확인: @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
